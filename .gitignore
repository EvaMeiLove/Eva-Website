# .gitignore — файлы которые НЕ загружаются на GitHub

# Зависимости (npm скачает их сам)
node_modules/
.pnp
.pnp.js

# Собранный сайт (Netlify собирает сам)
.next/
out/
dist/

# Переменные окружения (секретные данные — не загружать!)
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Логи
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Кеш
.cache/
.turbo/

# OS файлы
.DS_Store
Thumbs.db
desktop.ini

# IDE файлы
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo
next-env.d.ts
